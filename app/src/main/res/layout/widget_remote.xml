<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#1C1B1F"
    android:padding="12dp">

    <TextView
        android:id="@+id/widget_device_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/widget_default_device"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/widget_btn_power"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:contentDescription="@string/power"
            android:src="@drawable/ic_power" />

        <ImageButton
            android:id="@+id/widget_btn_vol_up"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:contentDescription="@string/volume_up"
            android:src="@drawable/ic_volume_up" />

        <ImageButton
            android:id="@+id/widget_btn_vol_down"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:background="@android:color/transparent"
            android:contentDescription="@string/volume_down"
            android:src="@drawable/ic_volume_down" />
    </LinearLayout>
</LinearLayout>
